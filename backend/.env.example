# Obrigatório: porta do servidor
PORT=3002

# Obrigatório: chave para o header X-API-Key (gateway rejeita requisições sem ela)
APP_API_KEY=

# Obrigatório: chave secreta para o JWT
JWT_SECRET=

# Supabase: conexão usada pela aplicação e pelo Prisma (modo transaction/supavisor).
# Troque as variáveis entre colchetes pelos seus valores no projeto do Supabase.
DATABASE_URL="postgres://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase: conexão "direta" (session mode) usada principalmente para migrations.
DIRECT_URL="postgres://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"
