generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admin {
  admin_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @db.VarChar(255)
  email       String        @unique @db.VarChar(255)
  password    String        @db.VarChar(255)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime?     @db.Timestamptz(6)
  appointment appointment[]
  doctor      doctor[]
  recipe      recipe[]
  specialty   specialty[]
}

model appointment {
  appointment_id   Int        @id @default(autoincrement())
  pet_id           String?    @db.Uuid
  appointment_date DateTime   @db.Timestamp(6)
  doctor_id        String?    @db.Uuid
  specialty_id     String?    @db.Uuid
  admin_id         String?    @db.Uuid
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?  @db.Timestamptz(6)
  admin            admin?     @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
  doctor           doctor?    @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade, onUpdate: NoAction)
  pet              pet?       @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade, onUpdate: NoAction)
  specialty        specialty? @relation(fields: [specialty_id], references: [specialty_id], onDelete: Cascade, onUpdate: NoAction)
}

model breed {
  breed_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)
  species_id  String?   @db.Uuid
  species     species?  @relation(fields: [species_id], references: [species_id], onDelete: Cascade, onUpdate: NoAction)
  pet         pet[]
}

model client {
  cpf        String    @id @db.VarChar(15)
  name       String    @db.VarChar(255)
  birth_date DateTime  @db.Date
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  pet        pet[]
  recipe     recipe[]
}

model doctor {
  doctor_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(255)
  cpf          String        @unique @db.VarChar(15)
  specialty_id String?       @db.Uuid
  admin_id     String?       @db.Uuid
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime?     @db.Timestamptz(6)
  appointment  appointment[]
  admin        admin?        @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
  specialty    specialty?    @relation(fields: [specialty_id], references: [specialty_id], onUpdate: NoAction)
  recipe       recipe[]
}

model pet {
  pet_id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(255)
  birth_date    DateTime?     @db.Date
  client_cpf    String?       @db.VarChar(15)
  breed_id      String?       @db.Uuid
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime?     @db.Timestamptz(6)
  is_neutered   Boolean?      @default(false)
  is_vaccinated Boolean?      @default(false)
  image_url     String?
  sex           String?       @db.VarChar(50)
  species_id    String?       @db.Uuid
  appointment   appointment[]
  breed         breed?        @relation(fields: [breed_id], references: [breed_id], onDelete: Cascade, onUpdate: NoAction)
  client        client?       @relation(fields: [client_cpf], references: [cpf], onDelete: Cascade, onUpdate: NoAction)
  species       species?      @relation(fields: [species_id], references: [species_id], onDelete: Cascade, onUpdate: NoAction)
  pet_vaccine   pet_vaccine[]
  recipe        recipe[]
}

model recipe {
  recipe_id   Int       @id @default(autoincrement())
  description String
  pet_id      String?   @db.Uuid
  client_cpf  String?   @db.VarChar(15)
  admin_id    String?   @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)
  pdf_url     String?
  doctor_id   String?   @db.Uuid
  admin       admin?    @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
  client      client?   @relation(fields: [client_cpf], references: [cpf], onDelete: Cascade, onUpdate: NoAction)
  doctor      doctor?   @relation(fields: [doctor_id], references: [doctor_id], onUpdate: NoAction)
  pet         pet?      @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade, onUpdate: NoAction)
}

model specialty {
  specialty_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @unique @db.VarChar(100)
  description  String?
  admin_id     String?       @db.Uuid
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime?     @db.Timestamptz(6)
  appointment  appointment[]
  doctor       doctor[]
  admin        admin?        @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pet_vaccine {
  pet_id     String  @db.Uuid
  vaccine_id String  @db.Uuid
  pet        pet     @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade, onUpdate: NoAction)
  vaccine    vaccine @relation(fields: [vaccine_id], references: [vaccine_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([pet_id, vaccine_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model vaccine {
  vaccine_id  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @unique @db.VarChar(100)
  pet_vaccine pet_vaccine[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model species {
  species_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)
  breed      breed[]
  pet        pet[]
}
