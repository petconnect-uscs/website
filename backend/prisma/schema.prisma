generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admin {
  admin_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @db.VarChar(255)
  email       String        @unique @db.VarChar(255)
  password    String        @db.VarChar(255)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime?     @db.Timestamptz(6)
  appointment appointment[]
  doctor      doctor[]
  recipe      recipe[]
  specialty   specialty[]
}

model appointment {
  appointment_id   Int        @id @default(autoincrement())
  pet_id           String?    @db.Uuid
  appointment_date DateTime   @db.Timestamp(6)
  doctor_id        String?    @db.Uuid
  specialty_id     String?    @db.Uuid
  admin_id         String?    @db.Uuid
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?  @db.Timestamptz(6)
  admin            admin?     @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
  doctor           doctor?    @relation(fields: [doctor_id], references: [doctor_id], onDelete: Cascade, onUpdate: NoAction)
  pet              pet?       @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade, onUpdate: NoAction)
  specialty        specialty? @relation(fields: [specialty_id], references: [specialty_id], onDelete: Cascade, onUpdate: NoAction)
}

model breed {
  breed_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)
  pet         pet[]
}

model client {
  cpf        String    @id @db.VarChar(15)
  name       String    @db.VarChar(255)
  birth_date DateTime  @db.Date
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  pet        pet[]
  recipe     recipe[]
}

model doctor {
  doctor_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(255)
  cpf          String        @unique @db.VarChar(15)
  specialty_id String?       @db.Uuid
  admin_id     String?       @db.Uuid
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime?     @db.Timestamptz(6)
  appointment  appointment[]
  admin        admin?        @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
  specialty    specialty?    @relation(fields: [specialty_id], references: [specialty_id], onUpdate: NoAction)
}

model pet {
  pet_id      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @db.VarChar(255)
  birth_date  DateTime?     @db.Date
  client_cpf  String?       @db.VarChar(15)
  breed_id    String?       @db.Uuid
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime?     @db.Timestamptz(6)
  appointment appointment[]
  breed       breed?        @relation(fields: [breed_id], references: [breed_id], onDelete: Cascade, onUpdate: NoAction)
  client      client?       @relation(fields: [client_cpf], references: [cpf], onDelete: Cascade, onUpdate: NoAction)
  recipe      recipe[]
}

model recipe {
  recipe_id   Int       @id @default(autoincrement())
  description String
  pet_id      String?   @db.Uuid
  client_cpf  String?   @db.VarChar(15)
  admin_id    String?   @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)
  admin       admin?    @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
  client      client?   @relation(fields: [client_cpf], references: [cpf], onDelete: Cascade, onUpdate: NoAction)
  pet         pet?      @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade, onUpdate: NoAction)
}

model specialty {
  specialty_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @unique @db.VarChar(100)
  description  String?
  admin_id     String?       @db.Uuid
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at   DateTime?     @db.Timestamptz(6)
  appointment  appointment[]
  doctor       doctor[]
  admin        admin?        @relation(fields: [admin_id], references: [admin_id], onUpdate: NoAction)
}
